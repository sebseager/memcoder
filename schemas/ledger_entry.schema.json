{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://memcoder.local/schemas/ledger_entry.schema.json",
  "title": "MemCoder ledger entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "lora_id",
    "topic",
    "title",
    "description",
    "example_questions"
  ],
  "properties": {
    "lora_id": {
      "type": "string",
      "description": "Human-readable LoRA ID referenced by routers and stores."
    },
    "topic": {
      "type": "string",
      "description": "Ledger section heading this entry appears under."
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "example_questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
