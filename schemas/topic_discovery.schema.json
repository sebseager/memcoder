{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://memcoder.local/schemas/topic_discovery.schema.json",
  "title": "MemCoder topic discovery artifact",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "repo_id",
    "commit",
    "generator",
    "prompt_version",
    "topics"
  ],
  "properties": {
    "repo_id": {
      "type": "string",
      "description": "Repository identifier using the owner__repo convention."
    },
    "commit": {
      "type": "string",
      "description": "Source repository commit used to discover topics."
    },
    "generator": {
      "type": "string",
      "description": "Tool or model that generated the topic artifact."
    },
    "prompt_version": {
      "type": "string",
      "description": "Prompt template version used to generate this artifact."
    },
    "seed_topics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "topics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "topic_slug",
          "title",
          "description",
          "evidence",
          "priority"
        ],
        "properties": {
          "topic_slug": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "evidence_pack_hint": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "priority": {
            "type": "string",
            "enum": ["initial", "high", "medium", "low"]
          }
        }
      }
    }
  }
}
