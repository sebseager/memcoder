{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://memcoder.local/schemas/lora_store.schema.json",
  "title": "MemCoder LoRA store",
  "type": "object",
  "additionalProperties": false,
  "required": ["repo_id", "commit", "difficulty", "loras"],
  "properties": {
    "repo_id": {
      "type": "string"
    },
    "commit": {
      "type": "string"
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "medium", "hard"]
    },
    "loras": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "lora_id",
          "topic",
          "difficulty",
          "source_document_path",
          "weights_path",
          "prompt_version",
          "generator"
        ],
        "properties": {
          "lora_id": {
            "type": "string"
          },
          "topic": {
            "type": "string"
          },
          "topic_slug": {
            "type": "string"
          },
          "difficulty": {
            "type": "string",
            "enum": ["easy", "medium", "hard"]
          },
          "source_document_path": {
            "type": "string"
          },
          "qa_pairs_path": {
            "type": "string"
          },
          "weights_path": {
            "type": ["string", "null"]
          },
          "example_questions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "embedding_path": {
            "type": ["string", "null"]
          },
          "prompt_version": {
            "type": "string"
          },
          "generator": {
            "type": "string"
          }
        }
      }
    }
  }
}
