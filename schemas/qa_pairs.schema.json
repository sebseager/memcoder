{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://memcoder.local/schemas/qa_pairs.schema.json",
  "title": "MemCoder QA pairs",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "repo_id",
    "commit",
    "document_id",
    "topic",
    "difficulty",
    "generator",
    "prompt_version",
    "qa_pairs"
  ],
  "properties": {
    "repo_id": {
      "type": "string"
    },
    "commit": {
      "type": "string"
    },
    "document_id": {
      "type": "string"
    },
    "topic": {
      "type": "string"
    },
    "topic_slug": {
      "type": "string"
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "medium", "hard"]
    },
    "generator": {
      "type": "string"
    },
    "prompt_version": {
      "type": "string"
    },
    "qa_pairs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["qa_id", "question", "answer"],
        "properties": {
          "qa_id": {
            "type": "string"
          },
          "question": {
            "type": "string",
            "minLength": 1
          },
          "answer": {
            "type": "string",
            "minLength": 1
          },
          "qa_set": {
            "type": "string"
          },
          "document_id": {
            "type": "string"
          }
        }
      }
    }
  }
}
